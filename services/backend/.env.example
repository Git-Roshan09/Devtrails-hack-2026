# ─────────────────────────────────────────────
# GigaChad Backend — FastAPI
# ─────────────────────────────────────────────

# App
APP_ENV=development
SECRET_KEY=gigachad_super_secret_key_change_in_prod

# Database (PostgreSQL)
# For Supabase, use the Transaction or Session pooler URL and prefix with postgresql+asyncpg://
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-xx-xxxx-x.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://gigachad:gigachad_secret@postgres:5432/gigachad_db

# Supabase (For Storage & Auth token decoding if needed)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Redis
REDIS_URL=redis://redis:6379

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gigachad_neo4j

# Groq LLM
GROQ_API_KEY=your_groq_api_key_here

# TimeGPT (Nixtla)
NIXTLA_API_KEY=your_nixtla_api_key_here

# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key_here

# TomTom Traffic
TOMTOM_API_KEY=your_tomtom_api_key_here

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio (WhatsApp Bot)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# S3 Evidence Storage
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your_bucket_name
